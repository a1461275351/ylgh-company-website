# ==========================================
# 杨凌国合跨境贸易官网项目 .gitignore
# 覆盖：Node.js 前端 + Spring Boot 后端
# ==========================================

# ---------- 操作系统 ----------
# macOS
.DS_Store
._*
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory


# ---------- IDE / 编辑器 ----------
# IntelliJ IDEA
.idea/
*.iml
*.ipr
*.iws
out/

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Eclipse
.classpath
.project
.settings/
.factorypath
.apt_generated/

# NetBeans
nbproject/private/
nbbuild/
nbdist/
.nb-gradle/

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
.\#*


# ---------- Java / Maven / Spring Boot (my-website-admin) ----------
target/
build/
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*

# Maven
.mvn/
mvnw
mvnw.cmd

# Spring Boot DevTools / 运行时
spring.log
application-local.yml
application-local.properties


# ---------- 运行时数据 / 上传 / 数据库 ----------
# H2 数据库文件（开发环境本地数据，不应入库）
my-website-admin/data/
*.mv.db
*.trace.db
*.h2.db
*.lock.db

# 用户上传文件
my-website-admin/uploads/

# 日志
logs/
*.log
log/


# ---------- Node.js / 前端 (my-website) ----------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# 构建产物
dist/
build/
.vite/
.cache/
.parcel-cache/
.next/
.nuxt/

# 环境变量
.env
.env.local
.env.*.local


# ---------- 项目内私有 / 临时文件 ----------
# Claude / AI 工具本地配置
.claude/
**/.claude/

# 压缩包（program.rar 等临时归档，不应入库）
*.rar
*.zip
*.7z
*.tar.gz
*.tgz

# 备份文件
*.bak
*.backup
*.old
*.orig


# ---------- 凭证 / 密钥 ----------
*.pem
*.key
*.p12
*.jks
*.keystore
secrets/
credentials.json
